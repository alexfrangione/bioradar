# Copy this file to `.env` and fill in the values.
# Do NOT commit the real .env file to Git (it's in .gitignore).

# Where the frontend is running. Used for CORS.
# Local dev:  http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Twelve Data API key — used for live quotes, price history fallback, and
# symbol search. Free tier is fine for dev.
# Get one at https://twelvedata.com/register
TWELVE_DATA_API_KEY=

# SEC EDGAR requires a descriptive User-Agent identifying who's hitting
# their free APIs (fair-access policy). Format: "AppName contact@email".
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=BioRadar research your-email@example.com

# Finnhub API key — powers the news layer of the catalyst feed. Free tier
# (60 req/min, no CC required) is plenty for this app. If unset, the news
# layer silently returns [] and the calendar falls back to seed + EDGAR +
# ClinicalTrials.gov only.
# Get one at https://finnhub.io/register
FINNHUB_API_KEY=
